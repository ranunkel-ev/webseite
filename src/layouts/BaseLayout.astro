---
import { createReader } from '@keystatic/core/reader';
import { ClientRouter } from 'astro:transitions';
import keystaticConfig from '../../keystatic.config';
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description: string;
  activePage?: string;
}

const { title, description, activePage } = Astro.props;

const reader = createReader(process.cwd(), keystaticConfig);
const site = await reader.singletons.site.read();
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
  <ClientRouter />
</head>
<body>

<SiteNav
  transition:persist
  activePage={activePage}
  brandPrimary={site?.nav?.brandPrimary}
  brandSub={site?.nav?.brandSub}
/>

<main class="site-main">
  <slot />
</main>

<SiteFooter transition:persist copy={site?.footer?.copy} />

<script>
  // Hamburger toggle (delegated, survives persisted nav across navigations)
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement)?.closest('#hamburger');
    if (!btn) return;
    document.getElementById('navlinks')?.classList.toggle('open');
  });

  // Keep the active nav link in sync when the nav is persisted across
  // client-side navigations (transition:persist + ClientRouter).
  document.addEventListener('astro:page-load', () => {
    const nav = document.getElementById('navlinks');
    if (!nav) return;
    nav.classList.remove('open');
    nav.querySelectorAll('a').forEach((a) => {
      const href = a.getAttribute('href');
      const isActive = !!href && href !== '/' && location.pathname.startsWith(href);
      a.classList.toggle('nav-active', isActive && !a.classList.contains('nav-cta'));
    });
  });
</script>

</body>
</html>
