---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import RichText from '../components/RichText';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.impressum.read();

const hero = page?.hero;
const bodyNodes = page?.body ? await page.body() : [];
const cta = page?.cta;
---

<BaseLayout
  title="Impressum — Ranunkel e.V."
  description="Impressum und rechtliche Angaben des Waldkindergartens Ranunkel e.V. in Waldkirch."
  activePage="/impressum"
>
  <div class="page-content">
    <div class="content-header">
      <div class="content-header-eyebrow">{hero?.eyebrow || 'Impressum'}</div>
      <div class="content-header-accent"></div>
      <h1>{hero?.title || 'Impressum'}</h1>
      {hero?.description && <p class="content-header-desc">{hero.description}</p>}
    </div>

    <div class="prose">
      <RichText document={bodyNodes} />
    </div>

    {cta?.enabled && (
      <div class="cta-bar" style="margin-top: 48px;">
        <p>{cta.text}</p>
        <div class="cta-bar-actions">
          {cta.buttonLabel && (
            <a href={cta.buttonHref || '#'} class="cta-bar-primary">{cta.buttonLabel}</a>
          )}
          {cta.secondaryLabel && (
            <a href={cta.secondaryHref || '#'} class="cta-bar-secondary">{cta.secondaryLabel}</a>
          )}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
