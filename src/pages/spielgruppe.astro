---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import '../styles/global.css';
import { docToHtml } from '../utils/docRenderer';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.spielgruppe.read();

const hero = page?.hero;
const infoBox = page?.infoBox ?? [];
const content = page?.content;
const activities = page?.activities;
const cta = page?.cta;

const contentNodes = content?.body ? await content.body() : [];
const contentHtml = docToHtml(contentNodes);

const activitiesNodes = activities?.body ? await activities.body() : [];
const activitiesHtml = docToHtml(activitiesNodes);
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Waldspielgruppen — Ranunkel e.V.</title>
  <meta name="description" content="Zwei betreute Waldspielgruppen für Kinder unter 3 Jahren in Waldkirch. Neugier, Bewegung und Naturerkundung von Anfang an." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- NAV -->
<nav class="sitenav">
  <a class="nav-logo" href="/" aria-label="Ranunkel e.V.">
    <svg width="34" height="34" viewBox="0 0 36 36" fill="none">
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(72, 18, 18)"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(144, 18, 18)"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(216, 18, 18)"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(288, 18, 18)"/>
      <circle cx="18" cy="18" r="5.5" fill="#b8834a"/>
    </svg>
    <div>
      <div class="nav-logo-text-primary">Ranunkel e.V.</div>
      <div class="nav-logo-text-sub">Waldkindergarten Waldkirch</div>
    </div>
  </a>
  <div class="nav-links" id="navlinks">
    <a href="/traegerverein">Trägerverein</a>
    <a href="/kindergarten">Kindergarten</a>
    <a href="/spielgruppe" class="nav-active">Spielgruppe</a>
    <a href="/aktuelles">Aktuelles</a>
    <a href="/faq">FAQ</a>
    <a href="/anmeldung" class="nav-cta">Anmeldung</a>
  </div>
  <button class="nav-hamburger" id="hamburger" aria-label="Menü öffnen">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- PAGE CONTENT -->
<div class="page-content">

  <!-- Page header -->
  <div class="content-header">
    <div class="content-header-eyebrow">{hero?.eyebrow || 'Waldspielgruppen'}</div>
    <div class="content-header-accent"></div>
    <h1>{hero?.title || 'Waldspielgruppen'}</h1>
    {hero?.quote && <p class="content-header-quote">„{hero.quote}"</p>}
  </div>

  <!-- Kurzinfos -->
  {infoBox.length > 0 && (
    <div class="info-grid">
      {infoBox.map((item, i) => (
        <div>
          <div class="info-grid-label">{item.label}</div>
          {i === 0 || i === 3
            ? <div class="info-grid-value" set:html={item.value.replace(/\n/g, '<br />')} />
            : <div class="info-grid-value-sm" set:html={item.value.replace(/\n/g, '<br />')} />
          }
        </div>
      ))}
    </div>
  )}

  <!-- Einleitung -->
  {content && (
    <div class="content-section">
      <h2>{content.heading || 'Den Wald von Anfang an erleben'}</h2>
      <Fragment set:html={contentHtml} />
    </div>
  )}

  <div class="content-divider"></div>

  <!-- Aktivitäten -->
  {activities && (
    <div class="content-section">
      <h2>{activities.heading || 'Was die Kinder im Wald erwartet'}</h2>
      <Fragment set:html={activitiesHtml} />
    </div>
  )}

  <!-- CTA -->
  <div class="cta-bar">
    <p>{cta?.text || 'Platz in der Spielgruppe sichern?'}</p>
    <div class="cta-bar-actions">
      <a href="/anmeldung" class="cta-bar-primary">{cta?.primaryLabel || 'Jetzt vormerken'}</a>
      <a href="/kontakt" class="cta-bar-secondary">{cta?.secondaryLabel || 'Kontakt'}</a>
    </div>
  </div>

</div>

<!-- FOOTER -->
<footer class="sitefooter">
  <div class="footer-copy">© 2026 Ranunkel e.V. · Rappeneckstraße 29, 79183 Waldkirch</div>
  <div class="footer-links">
    <a href="/impressum">Impressum</a>
    <a href="/datenschutz">Datenschutz</a>
    <a href="/kontakt">Kontakt</a>
  </div>
</footer>

<script>
(function () {
  const btn = document.getElementById('hamburger');
  const nav = document.getElementById('navlinks');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      nav.classList.toggle('open');
    });
  }
})();
</script>

</body>
</html>
