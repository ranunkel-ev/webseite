---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import ClickableImage from '../components/ClickableImage';
import { buildAktuellesSlugs } from '../utils/slug';
import { nodesToPlainText } from '../utils/plainText';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.aktuelles.read();

const hero = page?.hero;
const rawItems = page?.items ?? [];
const slugs = buildAktuellesSlugs(rawItems);

const items = await Promise.all(
  rawItems.map(async (item, index) => {
    const bodyNodes = item.body ? await item.body() : [];
    const plain = nodesToPlainText(bodyNodes);
    const truncated = plain.length > 160;
    const teaser = truncated ? `${plain.slice(0, 160).trimEnd()}…` : plain;
    return { ...item, teaser, truncated, slug: slugs[index] };
  })
);
---

<BaseLayout
  title="Aktuelles — Ranunkel e.V."
  description="Neuigkeiten, Hinweise und Termine aus dem Waldkindergarten und den Spielgruppen."
  activePage="/aktuelles"
>
  <div class="page-content">
    <div class="content-header">
      <div class="content-header-eyebrow">{hero?.eyebrow || 'Aktuelles'}</div>
      <div class="content-header-accent"></div>
      <h1>{hero?.title || 'Aktuelles'}</h1>
      {hero?.description && <p class="content-header-desc">{hero.description}</p>}
    </div>

    {hero?.image && <img class="content-header-img" src={hero.image} alt={hero.title || ''} />}

    <div>
      {items.map((item) => (
        <article class={`article${item.image ? ' article--has-image' : ''}`}>
          {item.image && (
            <ClickableImage src={item.image} alt={item.title} className="article-img" client:visible />
          )}
          <div class="article-body">
            <div class="article-meta">
              {item.highlight && (
                <span class="article-tag article-tag--highlight">Highlight</span>
              )}
              {item.date && <span class="article-date">{item.date}</span>}
            </div>
            <h2>{item.title}</h2>
            {item.teaser && <p>{item.teaser}</p>}
            {item.truncated && (
              <a class="btn-link article-readmore" href={`/aktuelles/${item.slug}`}>Mehr erfahren →</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
