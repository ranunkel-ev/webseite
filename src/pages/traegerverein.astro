---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import '../styles/global.css';
import { docToHtml } from '../utils/docRenderer';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.traegerverein.read();

const hero = page?.hero;
const founding = page?.founding;
const tasks = page?.tasks;
const financing = page?.financing;
const membership = page?.membership;
const cta = page?.cta;

const foundingNodes = founding?.content ? await founding.content() : [];
const foundingHtml = docToHtml(foundingNodes);

const tasksNodes = tasks?.content ? await tasks.content() : [];
const tasksHtml = docToHtml(tasksNodes);

const financingNodes = financing?.content ? await financing.content() : [];
const financingHtml = docToHtml(financingNodes);
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Der Trägerverein — Ranunkel e.V.</title>
  <meta name="description" content="Der gemeinnützige Elternverein Ranunkel e.V. trägt seit 1997 den Waldkindergarten und die Waldspielgruppen in Waldkirch." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- NAV -->
<nav class="sitenav">
  <a class="nav-logo" href="/" aria-label="Ranunkel e.V.">
    <svg width="34" height="34" viewBox="0 0 36 36" fill="none">
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(72, 18, 18)"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(144, 18, 18)"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(216, 18, 18)"/>
      <ellipse cx="18" cy="9" rx="4.5" ry="7" fill="#2d4a2f" transform="rotate(288, 18, 18)"/>
      <circle cx="18" cy="18" r="5.5" fill="#b8834a"/>
    </svg>
    <div>
      <div class="nav-logo-text-primary">Ranunkel e.V.</div>
      <div class="nav-logo-text-sub">Waldkindergarten Waldkirch</div>
    </div>
  </a>
  <div class="nav-links" id="navlinks">
    <a href="/traegerverein" class="nav-active">Trägerverein</a>
    <a href="/kindergarten">Kindergarten</a>
    <a href="/spielgruppe">Spielgruppe</a>
    <a href="/aktuelles">Aktuelles</a>
    <a href="/faq">FAQ</a>
    <a href="/anmeldung" class="nav-cta">Anmeldung</a>
  </div>
  <button class="nav-hamburger" id="hamburger" aria-label="Menü öffnen">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- PAGE CONTENT -->
<div class="page-content">

  <!-- Page header -->
  <div class="content-header">
    <div class="content-header-eyebrow">{hero?.eyebrow || 'Trägerverein'}</div>
    <div class="content-header-accent"></div>
    <h1>{hero?.title || 'Der Trägerverein'}</h1>
    <p class="content-header-desc">{hero?.description || 'Ein gemeinnütziger Elternverein, der seit 1997 den Waldkindergarten und die Waldspielgruppen in Waldkirch trägt und gestaltet.'}</p>
  </div>

  <!-- Entstehung -->
  <div class="content-section">
    <h2>{founding?.heading || 'Von der Idee zum Verein'}</h2>
    <Fragment set:html={foundingHtml} />
  </div>

  <div class="content-divider"></div>

  <!-- Aufgaben -->
  <div class="content-section">
    <h2>{tasks?.heading || 'Was der Verein tut'}</h2>
    <Fragment set:html={tasksHtml} />
  </div>

  <div class="content-divider"></div>

  <!-- Finanzierung -->
  <div class="content-section">
    <h2>{financing?.heading || 'Finanzierung'}</h2>
    <Fragment set:html={financingHtml} />
  </div>

  <div class="content-divider"></div>

  <!-- Mitgliedschaft -->
  <div class="content-section">
    <h2>{membership?.heading || 'Mitgliedschaft'}</h2>
    <p>{membership?.text || 'Als Elternteil eines Kindes im Kindergarten oder der Spielgruppe werden Sie automatisch Vereinsmitglied. Der Verein lebt vom Engagement seiner Mitglieder — jede helfende Hand ist willkommen.'}</p>
  </div>

  <!-- CTA -->
  <div class="cta-bar">
    <p>{cta?.description || 'Fragen zum Verein oder zur Mitgliedschaft?'}</p>
    <a href="/kontakt" class="cta-bar-primary">{cta?.buttonText || 'Kontakt aufnehmen'}</a>
  </div>

</div>

<!-- FOOTER -->
<footer class="sitefooter">
  <div class="footer-copy">© 2026 Ranunkel e.V. · Rappeneckstraße 29, 79183 Waldkirch</div>
  <div class="footer-links">
    <a href="/impressum">Impressum</a>
    <a href="/datenschutz">Datenschutz</a>
    <a href="/kontakt">Kontakt</a>
  </div>
</footer>

<script>
(function () {
  var btn = document.getElementById('hamburger');
  var nav = document.getElementById('navlinks');
  if (btn && nav) {
    btn.addEventListener('click', function () {
      nav.classList.toggle('open');
    });
  }
})();
</script>

</body>
</html>
