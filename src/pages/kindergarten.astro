---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import RichText from '../components/RichText';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.kindergarten.read();

const hero = page?.hero;
const infoBox = page?.infoBox ?? [];
const bodyNodes = page?.body ? await page.body() : [];
const cta = page?.cta;
---

<BaseLayout
  title="Waldkindergarten — Ranunkel e.V."
  description="Waldkindergarten für 3- bis 6-jährige Kinder in Waldkirch. Bewusst, sorgsam und respektvoll mit allem Lebendigen umgehen."
  activePage="/kindergarten"
>
  <div class="page-content">
    <div class="content-header">
      <div class="content-header-eyebrow">{hero?.eyebrow || 'Waldkindergarten'}</div>
      <div class="content-header-accent"></div>
      <h1>{hero?.title || 'Waldkindergarten'}</h1>
      {hero?.quote && <p class="content-header-quote">„{hero.quote}"</p>}
    </div>

    {hero?.image && <img class="content-header-img" src={hero.image} alt={hero.title || ''} />}

    {infoBox.length > 0 && (
      <div class="fact-strip" style={`--fact-cols: ${infoBox.length}`}>
        {infoBox.map((item) => (
          <div>
            <div class="fact-strip-label">{item.label}</div>
            <div class="fact-strip-value" set:html={item.value.replace(/\n/g, '<br />')} />
          </div>
        ))}
      </div>
    )}

    <div class="prose">
      <RichText document={bodyNodes} />
    </div>

    {cta?.enabled && (
      <div class="cta-bar" style="margin-top: 48px;">
        <p>{cta.text}</p>
        <div class="cta-bar-actions">
          {cta.buttonLabel && (
            <a href={cta.buttonHref || '#'} class="cta-bar-primary">{cta.buttonLabel}</a>
          )}
          {cta.secondaryLabel && (
            <a href={cta.secondaryHref || '#'} class="cta-bar-secondary">{cta.secondaryLabel}</a>
          )}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
