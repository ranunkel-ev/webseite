---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import RichText from '../components/RichText';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.faq.read();

const hero = page?.hero;
const bodyNodes = page?.body ? await page.body() : [];
const cta = page?.cta;
---

<BaseLayout
  title="FAQ — Ranunkel e.V."
  description="Häufige Fragen rund um Kindergarten und Spielgruppen bei Ranunkel e.V. in Waldkirch."
  activePage="/faq"
>
  <div class="page-content">
    <div class="content-header">
      <div class="content-header-eyebrow">{hero?.eyebrow || 'Häufige Fragen'}</div>
      <div class="content-header-accent"></div>
      <h1>{hero?.title || 'FAQ'}</h1>
      {hero?.description && <p class="content-header-desc">{hero.description}</p>}
    </div>

    <div class="prose">
      <RichText document={bodyNodes} />
    </div>

    {cta && (
      <div class="cta-bar" style="margin-top: 64px;">
        <p>{cta.text}</p>
        <div class="cta-bar-actions">
          <a href="/kontakt" class="cta-bar-primary">{cta.buttonText}</a>
        </div>
      </div>
    )}
  </div>
</BaseLayout>
